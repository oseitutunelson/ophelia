generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mongodb"
  url          = env("DATABASE_URL")
}

model Profile {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  username    String    @unique
  bio         String?
  profilePicture String?
  githubUrl   String?
  linkedinUrl String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Pro subscription fields
  isPro                Boolean   @default(false)
  isAgencyPro          Boolean   @default(false)
  proExpiresAt         DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  paystackCustomerId   String?
  paystackSubscriptionCode String?

  @@index([userId])
}

model Work {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  title       String
  description String
  image       String
  liveSiteUrl String
  githubUrl   String
  category    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  likes     Like[]
  bookmarks Bookmark[]

  @@index([userId])
}

model Like {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  workId    String
  createdAt DateTime @default(now())

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workId])
}

model Bookmark {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  workId    String
  createdAt DateTime @default(now())

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workId])
}

model ProfileBookmark {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   // User who bookmarked
  talentId  String   // User ID of the designer being bookmarked
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([talentId])
  @@unique([userId, talentId])  // One bookmark per user per profile
}

model Job {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  title       String
  description String
  category    String
  location    String?
  salary      String?
  jobType     String   // "Full-time", "Part-time", "Freelance", "Contract"
  experience  String?  // "Entry", "Mid", "Senior"
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([category])
}

model JobApplication {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  jobId     String
  userId    String
  message   String
  workId    String?  // Optional: link to existing portfolio project
  portfolioUrl String?  // Optional: custom link to portfolio, GitHub, etc
  status    String   @default("pending")  // "pending", "accepted", "rejected"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([userId])
  @@unique([jobId, userId])  // One application per user per job
}

model Follow {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  followerId  String   // User who is following
  followingId String   // User being followed
  createdAt   DateTime @default(now())

  @@index([followerId])
  @@index([followingId])
  @@unique([followerId, followingId])  // Prevent duplicate follows
}

model Conversation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants String[]  // Array of user IDs
  messages     Message[]

  @@index([participants])
}

model Message {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model BlogPost {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  slug            String   @unique
  title           String
  excerpt         String?
  content         String
  coverImage      String?
  category        String
  tags            String[]
  authorId        String
  status          String   @default("published")
  readTime        Int      @default(5)
  metaDescription String?
  viewCount       Int      @default(0)
  featured        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  comments  BlogComment[]
  likes     BlogLike[]
  bookmarks BlogBookmark[]

  @@index([authorId])
  @@index([category])
  @@index([status])
  @@index([createdAt])
}

model BlogComment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
}

model BlogLike {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@unique([postId, userId])
}

model BlogBookmark {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@unique([postId, userId])
}

model AdCampaign {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  userId         String
  type           String    // "design" | "agency" | "job" | "blog"
  contentId      String    // ID of promoted content; empty string for agency type
  contentTitle   String
  contentImage   String?
  status         String    @default("pending_payment")
  // "pending_payment" | "active" | "paused" | "expired"
  duration       Int       // 7 | 14 | 30 days
  price          Float
  startDate      DateTime?
  endDate        DateTime?
  impressions    Int       @default(0)
  clicks         Int       @default(0)
  stripeSessionId String?
  paystackRef    String?
  paymentStatus  String    @default("pending") // "pending" | "paid" | "failed"
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type, status])
  @@index([endDate])
}

// ── Learning Platform ─────────────────────────────────────────────────────────

model InstructorApplication {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @unique
  fullName        String
  bio             String
  expertise       String[]
  experience      String
  portfolioUrl    String?
  sampleLessonUrl String?
  status          String   @default("pending") // "pending" | "approved" | "rejected"
  reviewNote      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
}

model Instructor {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique
  bio           String?
  expertise     String[]
  website       String?
  twitter       String?
  instagram     String?
  youtube       String?
  isVerified    Boolean  @default(false)
  totalStudents Int      @default(0)
  totalCourses  Int      @default(0)
  rating        Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  courses Course[]
}

model Course {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  slug             String   @unique
  title            String
  description      String
  shortDescription String?
  thumbnail        String?
  previewVideo     String?
  instructorId     String
  category         String
  level            String   @default("Beginner")
  language         String   @default("English")
  price            Float    @default(0)
  isFree           Boolean  @default(true)
  isPublished      Boolean  @default(false)
  isFeatured       Boolean  @default(false)
  totalDuration    Int      @default(0)
  totalLessons     Int      @default(0)
  requirements     String[]
  objectives       String[]
  tags             String[]
  hasCertificate   Boolean  @default(true)
  metaDescription  String?
  enrollmentCount  Int      @default(0)
  rating           Float    @default(0)
  ratingCount      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  instructor  Instructor     @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  modules     CourseModule[]
  enrollments Enrollment[]
  reviews     CourseReview[]
  bookmarks   CourseBookmark[]

  @@index([instructorId])
  @@index([category])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([createdAt])
}

model CourseModule {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  courseId    String
  title       String
  description String?
  order       Int
  createdAt   DateTime @default(now())

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  moduleId    String
  title       String
  description String?
  type        String   @default("video") // "video" | "text" | "resource"
  content     String?
  duration    Int      @default(0)
  order       Int
  isFree      Boolean  @default(false)
  resources   String[]
  createdAt   DateTime @default(now())

  module   CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@index([moduleId])
}

model Enrollment {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String
  courseId        String
  status          String    @default("active")
  paymentStatus   String    @default("free")
  stripeSessionId String?
  paidAt          DateTime?
  completedAt     DateTime?
  progressPct     Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@index([userId])
  @@index([courseId])
  @@unique([userId, courseId])
}

model LessonProgress {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  userId         String
  lessonId       String
  enrollmentId   String
  completed      Boolean   @default(false)
  completedAt    DateTime?
  watchedSeconds Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lessonId])
  @@index([enrollmentId])
  @@unique([userId, lessonId])
}

model CourseReview {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  courseId  String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([userId])
  @@unique([courseId, userId])
}

model Certificate {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String
  courseId       String
  courseTitle    String
  instructorName String
  completedAt    DateTime @default(now())
  certificateId  String   @unique

  @@index([userId])
  @@index([courseId])
}

model CourseBookmark {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
  @@unique([userId, courseId])
}

model LearningStreak {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  userId           String    @unique
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime?
  totalDaysLearned Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}