generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mongodb"
  url          = env("DATABASE_URL")
}

model Profile {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  username    String    @unique
  bio         String?
  profilePicture String?
  githubUrl   String?
  linkedinUrl String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
}

model Work {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  title       String
  description String
  image       String
  liveSiteUrl String
  githubUrl   String
  category    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  likes     Like[]
  bookmarks Bookmark[]

  @@index([userId])
}

model Like {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  workId    String
  createdAt DateTime @default(now())

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workId])
}

model Bookmark {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  workId    String
  createdAt DateTime @default(now())

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workId])
}

model ProfileBookmark {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   // User who bookmarked
  talentId  String   // User ID of the designer being bookmarked
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([talentId])
  @@unique([userId, talentId])  // One bookmark per user per profile
}

model Job {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  title       String
  description String
  category    String
  location    String?
  salary      String?
  jobType     String   // "Full-time", "Part-time", "Freelance", "Contract"
  experience  String?  // "Entry", "Mid", "Senior"
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([category])
}

model JobApplication {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  jobId     String
  userId    String
  message   String
  workId    String?  // Optional: link to existing portfolio project
  portfolioUrl String?  // Optional: custom link to portfolio, GitHub, etc
  status    String   @default("pending")  // "pending", "accepted", "rejected"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([userId])
  @@unique([jobId, userId])  // One application per user per job
}

model Follow {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  followerId  String   // User who is following
  followingId String   // User being followed
  createdAt   DateTime @default(now())

  @@index([followerId])
  @@index([followingId])
  @@unique([followerId, followingId])  // Prevent duplicate follows
}

model Conversation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants String[]  // Array of user IDs
  messages     Message[]

  @@index([participants])
}

model Message {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}